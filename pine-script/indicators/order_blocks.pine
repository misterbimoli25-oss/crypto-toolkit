//@version=6
// Order Blocks — ICT-Style Bullish & Bearish Order Block Detection
// Author: Fian Dev | fiverr.com/mrxx_25

indicator("Order Blocks", overlay=true)

// ─── Inputs ──────────────────────────────────────────
obLookback   = input.int(20, "OB Lookback", minval=5, maxval=100)
obMitigation = input.string("Close", "Mitigation", options=["Close", "Wick", "50%"])
showActive   = input.bool(true, "Show Active OBs")
showMitigated = input.bool(false, "Show Mitigated OBs")
maxOBs       = input.int(10, "Max Visible OBs", minval=1, maxval=50)

// ─── Order Block Detection ──────────────────────────
type OrderBlock
    float top
    float bottom
    bool  isBullish
    bool  mitigated
    int   barIndex

var OrderBlock[] activeOBs = array.new<OrderBlock>()

// Bullish OB: last bearish candle before a higher high
bullishCondition = close > high[1] and close[1] < open[1]
// Bearish OB: last bullish candle before a lower low
bearishCondition = close < low[1] and close[1] > open[1]

if bullishCondition
    obTop    = math.max(open[1], close[1])
    obBottom = math.min(open[1], close[1])
    array.unshift(activeOBs, OrderBlock.new(obTop, obBottom, true, false, bar_index))

if bearishCondition
    obTop    = math.max(open[1], close[1])
    obBottom = math.min(open[1], close[1])
    array.unshift(activeOBs, OrderBlock.new(obTop, obBottom, false, false, bar_index))

// ─── Mitigation Check ────────────────────────────────
for i = 0 to array.size(activeOBs) - 1
    ob = array.get(activeOBs, i)
    if not ob.mitigated
        mitigated = false
        if ob.isBullish
            mitigated := switch obMitigation
                "Close" => low  <= ob.bottom
                "Wick"  => low  <= ob.bottom - (ob.top - ob.bottom) * 0.1
                "50%"   => close <= (ob.top + ob.bottom) / 2
        else
            mitigated := switch obMitigation
                "Close" => high >= ob.top
                "Wick"  => high >= ob.top + (ob.top - ob.bottom) * 0.1
                "50%"   => close >= (ob.top + ob.bottom) / 2
        if mitigated
            ob.mitigated := true

// ─── Cleanup Old ─────────────────────────────────────
if array.size(activeOBs) > maxOBs * 2
    for i = array.size(activeOBs) - 1 to 0 by 1
        ob = array.get(activeOBs, i)
        if ob.mitigated and bar_index - ob.barIndex > 100
            array.remove(activeOBs, i)

// ─── Plot OBs ────────────────────────────────────────
plottedCount = 0
for i = 0 to array.size(activeOBs) - 1
    if plottedCount >= maxOBs
        break
    ob = array.get(activeOBs, i)
    shouldPlot = (ob.mitigated and showMitigated) or (not ob.mitigated and showActive)
    if shouldPlot
        obAlpha = ob.mitigated ? 40 : 75
        obColor = ob.isBullish ? color.new(color.green, obAlpha) : color.new(color.red, obAlpha)
        box.new(ob.barIndex, ob.top, bar_index + 20, ob.bottom,
            obColor, 1, line.style_solid, color.new(color.white, 50),
            bgcolor=obColor)
        plottedCount += 1

// ─── Alerts ─────────────────────────────────────────
alertcondition(bullishCondition, "Bullish OB Formed", "New bullish order block detected")
alertcondition(bearishCondition, "Bearish OB Formed", "New bearish order block detected")
